# Jira Cloud API credentials
# Copy this file to .env and fill in your values
#
# 1. Go to https://id.atlassian.com/manage-profile/security/api-tokens
# 2. Click "Create API token", name it "M&S Log Analysis Toolkit"
# 3. Copy the token and paste below
# 4. Run ./scripts/setup/verify-jira-access.sh to verify

JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
